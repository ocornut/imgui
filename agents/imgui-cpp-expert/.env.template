# ImGui C++ Expert Agent Configuration
# Copy this to .env and fill in your values

# Anthropic API Key (required)
# Get your key from: https://console.anthropic.com/
# With Copilot Pro, your key is included in your subscription
ANTHROPIC_API_KEY=sk-ant-...

# Enable verbose output of extended thinking process (optional)
# Set to 1 to see the agent's reasoning steps
VERBOSE_THINKING=0

# Server mode configuration (optional)
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8000
